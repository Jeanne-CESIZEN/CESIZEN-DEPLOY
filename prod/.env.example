# Copier en .env dans deploy/prod/ sur la VM. NE JAMAIS committer (secrets).
DOMAIN=cesizen.mondomaine.fr

# Base de données PostgreSQL (prod)
DATABASE_NAME=cesizen
DATABASE_USERNAME=cesizen
DATABASE_PASSWORD=change-me-strong-password-prod

# Secrets JWT (openssl rand -hex 32)
JWT_ACCESS_SECRET=change-me-prod
JWT_REFRESH_SECRET=change-me-prod
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d
