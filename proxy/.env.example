# Copier en .env dans deploy/proxy/ sur la VM.

# Email utilisé par Let's Encrypt pour les certificats.
ACME_EMAIL=admin@mondomaine.fr

# Domaine de base : le dashboard Traefik sera exposé sur https://traefik.DOMAIN
DOMAIN=cesizen.jeanne-grenet.fr

# Authentification du dashboard Traefik (basic auth).
# Générer avec :  htpasswd -nb admin 'MotDePasseFort'
# IMPORTANT : dans CE fichier .env, DOUBLER chaque $ du hash ($ -> $$),
# sinon docker compose les interprète comme des variables.
# Exemple (hash factice) :
TRAEFIK_DASHBOARD_AUTH=admin:$$apr1$$abcd1234$$exempleDeHashÀRemplacer.
