# Copier en .env dans deploy/staging/ sur la VM. NE JAMAIS committer (secrets).
DOMAIN=staging.cesizen.mondomaine.fr

# Base de données PostgreSQL (staging) — séparée de la prod
DATABASE_NAME=cesizen
DATABASE_USERNAME=cesizen
DATABASE_PASSWORD=change-me-strong-password-staging

# Secrets JWT (openssl rand -hex 32) — distincts de la prod
JWT_ACCESS_SECRET=change-me-staging
JWT_REFRESH_SECRET=change-me-staging
JWT_ACCESS_TOKEN_TTL=15m
JWT_REFRESH_TOKEN_TTL=7d
